# PawAI repo-root local env template.
# Copy to .env.local and fill in your values.
#
# Read by:
#   - tools/pawai_cli (pawai doctor / deploy / demo / status)
#   - scripts/start_*.sh
#   - .claude/skills/brain-studio-lane/scripts/start.sh
#
# Variables are loaded with .env (committed defaults) as base, then .env.local
# overrides. Keep secrets ONLY in .env.local.

# ── Jetson / network ─────────────────────────────────────────────────────
# SSH alias for the Jetson (matches Host block in ~/.ssh/config).
# Common values: jetson  /  jetson-nano  /  orin
JETSON_HOST=jetson

# Path to the repo on Jetson — rsync target for `pawai jetson deploy`.
JETSON_REPO=/home/jetson/elder_and_dog

# JETSON_TAILSCALE_IP=
# Leave blank — CLI auto-detects via `tailscale status` using JETSON_HOSTNAME_HINT
JETSON_HOSTNAME_HINT=jetson

# Go2 robot IP (Ethernet preferred to avoid Wi-Fi OTA auto-update).
ROBOT_IP=192.168.123.161
CONN_TYPE=webrtc

# ── LLM / TTS / ASR ──────────────────────────────────────────────────────
# OpenRouter is the cloud LLM provider for brain (gpt-5.4-mini main +
# gemini-3-flash fallback). Get key from https://openrouter.ai/keys
OPENROUTER_KEY=sk-or-v1-REPLACE_ME

PAWAI_LLM_MODEL=openai/gpt-5.4-mini
PAWAI_LLM_FALLBACK_MODEL=google/gemini-3-flash-preview

TTS_PROVIDER=openrouter_gemini
OPENROUTER_GEMINI_VOICE=Despina

# ASR provider chain (first reachable wins).
ASR_PROVIDER_ORDER=["sensevoice_cloud","sensevoice_local","whisper_local"]
