# PawAI Studio frontend — local env template
# Copy to .env.local and fill in actual values.
#
# `pawai demo start` (Mac-side workflow) reads JETSON_TAILSCALE_IP from the
# repo-root .env.local and writes this file automatically. If you're starting
# the frontend manually, set NEXT_PUBLIC_GATEWAY_URL to your Jetson reachable
# address (Tailscale IP or LAN IP), port 8080.

# Full explicit form (recommended) — takes precedence over GATEWAY_HOST below.
# NEXT_PUBLIC_GATEWAY_URL=http://100.83.109.89:8080

# Short form — hostname only, port defaults to 8080.
NEXT_PUBLIC_GATEWAY_HOST=100.83.109.89

# Override WS URL explicitly (rare; usually derived from GATEWAY_URL above).
# NEXT_PUBLIC_WS_URL=ws://100.83.109.89:8080/ws/events

# Hard-reset gateway on every page refresh (DEV ONLY — wipes Jetson state)
# NEXT_PUBLIC_AUTO_RESET_ON_REFRESH=false

# Optional: pose inference HTTP endpoint (only used by /studio/pose panel)
# NEXT_PUBLIC_POSE_INFER_ENDPOINT=http://127.0.0.1:8765/pose/infer
