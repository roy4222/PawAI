# ============================================================
# config/school_demo.env — Demo 啟動環境設定（學校場地）
# ============================================================
#
# 用途：5/12 移交學校後，所有 demo 相關 script 都先 source 這個檔，
# 統一網路 / 路徑 / endpoint 設定。家裡 vs 學校切換只改這個檔。
#
# 用法（兩擇一）：
#   # 法 A：先設 JETSON_IP 再 source
#   JETSON_IP=192.168.1.42 source config/school_demo.env
#
#   # 法 B：先 export GATEWAY_HOST（用 hostname alias 也行）
#   export GATEWAY_HOST=jetson-school
#   source config/school_demo.env
#
# 之後跑：
#   bash scripts/start_full_demo_tmux.sh
#   bash scripts/start_nav_capability_demo_tmux.sh
#   ...都會自動讀此檔的環變
#
# ============================================================

# --- 硬檢查：JETSON_IP 或 GATEWAY_HOST 至少要有一個 ---
# 不允許 silent default 成 http://:8080 — 現場會以不明確方式失敗
if [[ -z "${JETSON_IP:-}" && -z "${GATEWAY_HOST:-}" ]]; then
  echo "❌ [school_demo.env] ERROR: JETSON_IP 或 GATEWAY_HOST 至少要設一個"
  echo "   用法："
  echo "     JETSON_IP=192.168.x.y source config/school_demo.env"
  echo "     # 或"
  echo "     GATEWAY_HOST=<jetson_hostname> source config/school_demo.env"
  return 1 2>/dev/null || exit 1
fi

# --- Network: Robot ---
export ROBOT_IP="${ROBOT_IP:-192.168.123.161}"          # Go2 Ethernet 直連
export CONN_TYPE="${CONN_TYPE:-webrtc}"
export ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-0}"

# --- Network: Jetson host ---
export JETSON_HOST="${JETSON_HOST:-jetson-school}"
# JETSON_IP / GATEWAY_HOST 至少一個會在此前已設

# --- Network: Studio gateway (Mac → Jetson) ---
export GATEWAY_HOST="${GATEWAY_HOST:-${JETSON_IP}}"
export GATEWAY_PORT="${GATEWAY_PORT:-8080}"
export NEXT_PUBLIC_GATEWAY_URL="http://${GATEWAY_HOST}:${GATEWAY_PORT}"

# --- Foxglove ---
export FOXGLOVE_PORT="${FOXGLOVE_PORT:-8765}"
# FOXGLOVE_URL 用 ws:// 動態組
export FOXGLOVE_URL="ws://${GATEWAY_HOST}:${FOXGLOVE_PORT}"

# --- LLM / ASR endpoints ---
# 學校環境若 SSH tunnel 開好，仍指 localhost；無 tunnel 則改雲端 IP
export LLM_ENDPOINT="${LLM_ENDPOINT:-http://localhost:8000/v1/chat/completions}"
export QWEN_ASR_BASE_URL="${QWEN_ASR_BASE_URL:-http://127.0.0.1:8001/v1/audio/transcriptions}"
# studio_gateway.py 讀 PAWAI_ASR_URL（fallback ASR_URL → default）
export PAWAI_ASR_URL="${PAWAI_ASR_URL:-${QWEN_ASR_BASE_URL}}"
export ASR_URL="${ASR_URL:-${QWEN_ASR_BASE_URL}}"

# --- Map / Runtime path ---
export MAP="${MAP:-/home/jetson/maps/school_demo.yaml}"
export PBSTREAM="${PBSTREAM:-/home/jetson/maps/school_demo.pbstream}"
export MAP_DIR="${MAP_DIR:-/home/jetson/maps}"
export NAV_RUNTIME_DIR="${NAV_RUNTIME_DIR:-${HOME}/elder_and_dog/runtime/nav_capability}"
# nav_capability 需 JSON 檔路徑（不是目錄）
export NAV_NAMED="${NAV_NAMED:-${NAV_RUNTIME_DIR}/named_poses/main.json}"
export NAV_ROUTES="${NAV_ROUTES:-${NAV_RUNTIME_DIR}/routes/}"

# --- WORKDIR / Models ---
export WORKDIR="${WORKDIR:-${HOME}/elder_and_dog}"
export MODEL_BASE="${MODEL_BASE:-/home/jetson/models}"

# --- Modes ---
export ENABLE_LOCAL_LLM="${ENABLE_LOCAL_LLM:-false}"
export DEMO_MODE="${DEMO_MODE:-school}"

# --- Print summary ---
cat <<EOF
[school_demo.env] ✅ loaded
  ROBOT_IP        = $ROBOT_IP
  GATEWAY         = $NEXT_PUBLIC_GATEWAY_URL
  FOXGLOVE        = $FOXGLOVE_URL
  LLM             = $LLM_ENDPOINT
  ASR (gateway)   = $PAWAI_ASR_URL
  ASR (qwen)      = $QWEN_ASR_BASE_URL
  MAP             = $MAP
  WORKDIR         = $WORKDIR
EOF
