# Go2 runtime
ROBOT_IP=192.168.123.161
CONN_TYPE=webrtc

# TTS API key (preferred)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional alias used by phase4 tmux script
TTS_API_KEY=${ELEVENLABS_API_KEY}

# Speech pipeline tuning
INPUT_DEVICE=0
SAMPLE_RATE=16000
CAPTURE_SAMPLE_RATE=44100
FRAME_SAMPLES=512
VAD_THRESHOLD=0.25
MIN_SILENCE_MS=150

# ASR / Intent defaults
ASR_MODEL_NAME=tiny
ASR_LANGUAGE=zh
INTENT_MIN_CONFIDENCE=0.55

# TTS voice/provider defaults
TTS_PROVIDER=piper
TTS_VOICE_NAME=XrExE9yKIg1WjnnlVkGX

# MeloTTS options (used when TTS_PROVIDER=melotts)
MELO_LANGUAGE=ZH
MELO_SPEAKER=ZH
MELO_SPEED=0.92
MELO_DEVICE=auto

# Piper options (used when TTS_PROVIDER=piper)
PIPER_MODEL_PATH=/home/jetson/models/piper/zh_CN-huayan-medium.onnx
PIPER_CONFIG_PATH=/home/jetson/models/piper/zh_CN-huayan-medium.onnx.json
PIPER_SPEAKER_ID=0
PIPER_LENGTH_SCALE=1.05
PIPER_NOISE_SCALE=0.667
PIPER_NOISE_W=0.8
PIPER_USE_CUDA=false
